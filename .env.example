# ---------------------------------------------------------------------------
# Plausible-Tracking (optional)
# ---------------------------------------------------------------------------
# Domain, wie sie im Plausible-Dashboard angelegt ist (ohne https://).
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=ticket-pilot.de
# Self-Hosted-Plausible? Script-URL hier ueberschreiben.
# NEXT_PUBLIC_PLAUSIBLE_SRC=https://stats.processcube.io/js/script.tagged-events.js


# ---------------------------------------------------------------------------
# A/B-Experiment (optional Notausschalter)
# ---------------------------------------------------------------------------
# Auf "false" setzen, um die Middleware den 50/50-Split ignorieren zu lassen.
# Danach sehen alle Besucher auf "/" die Variante A (Default).
EXPERIMENT_AB_ACTIVE=true


# ---------------------------------------------------------------------------
# Odoo-CRM-Anbindung fuer /api/lead
# ---------------------------------------------------------------------------
# Wenn diese vier Variablen gesetzt sind, legt jede Trial-Anfrage
# (Lead-Formular in Variante B/C) automatisch ein crm.lead in eurem Odoo an.
# Wenn sie NICHT gesetzt sind, laeuft die Route lokal als Stub weiter.
#
# Health-Check: curl https://ticket-pilot.de/api/lead/odoo-health
# Erwartete Antwort: {"ok":true,"uid":<zahl>}

ODOO_URL=https://www.processcube.io
ODOO_DB=your-db-name
ODOO_USERNAME=cuby@processcube.io
ODOO_API_KEY=odoo_api_key_named_ticketpilot-lead-api

# Optional, aber empfohlen: CRM-Zuordnungen (per Name aufgeloest).
# Wenn der angegebene Name in Odoo nicht existiert, wird das Feld einfach
# weggelassen. Keine Sorge um Typos \u2013 nichts zerbricht, du siehst's nur
# nicht in der CRM-Ansicht.
ODOO_SALES_TEAM=Ticketpilot Sales        # crm.team
ODOO_LEAD_SOURCE=Ticketpilot Landing     # utm.source
ODOO_LEAD_TAG=Ticketpilot Trial          # crm.tag
